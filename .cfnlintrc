# Config de cfn-lint. Lintea los 7 templates del proyecto (repartidos en
# templates/{bootstrap,infra,app}/ con extensión .yaml o .yml según el archivo).
templates:
  - templates/**/*.yaml
  - templates/**/*.yml

# Ignora warnings conocidos aceptados para el MVP.
# W1011 recomienda usar dynamic references (SSM SecureString / Secrets Manager)
# en lugar de pasar secretos como parámetros de CloudFormation.
# Se mantiene temporalmente porque los secretos son gestionados externamente.
ignore_checks:
  - W1011